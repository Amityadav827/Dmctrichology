# Backend local/deployment environment
# Copy to .env locally or configure these in Render dashboard.
# Placeholder values only. Never commit real secrets.

NODE_ENV=development
PORT=4000

MONGO_URI=mongodb+srv://username:password@cluster.example.com/database?retryWrites=true&w=majority

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

EMAIL_USER=your-email@example.com
EMAIL_PASS=your_email_app_password

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
